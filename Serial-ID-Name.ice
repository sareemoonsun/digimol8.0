          "type": "basic.code",
          "data": {
            "ports": {
              "in": [
                {
                  "name": "m_clk"
                }
              ],
              "out": [
                {
                  "name": "m_out",
                  "range": "[7:0]",
                  "size": 8
                }
              ]
            },
            "params": [
              {
                "name": "ROM"
              }
            ],
            "code": "reg[7:0] m_out;\nreg[6:0] temp;\nreg[7:0] rom[0:25];\n\ninitial begin\n    temp = 6'b000000;\nend\n\nalways @(posedge m_clk) begin\n    temp = temp + 1'b1;\n    case(temp)\n        6'd26: m_out = 8'b00001010;\n        6'd27: m_out = 8'b00001101;\n        6'd28: temp  = 6'b000000;\n        default: m_out = rom[temp];\n    endcase\nend\n\ninitial begin\n    if (ROM) $readmemh(ROM, rom);\nend"
          },
          "position": {
            "x": 616,
            "y": -8
          },
          "size": {
            "width": 568,
            "height": 376
          }
